{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "datasource", "uid": "grafana" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "title": "Resumen del sistema",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [
            { "options": { "0": { "text": "DOWN", "color": "red" } }, "type": "value" },
            { "options": { "1": { "text": "UP", "color": "green" } }, "type": "value" }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          }
        }
      },
      "gridPos": { "h": 5, "w": 24, "x": 0, "y": 1 },
      "id": 1,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "textMode": "value_and_name",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }
      },
      "pluginVersion": "10.0.0",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "up{job=~\"empleados-service|departamentos-service|notificaciones-service|autenticacion-service|perfiles-service\"}",
          "legendFormat": "{{job}}",
          "refId": "A"
        }
      ],
      "title": "Estado de cada servicio (up)",
      "type": "stat"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 6 },
      "id": 101,
      "title": "Comportamiento del tráfico",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Peticiones/segundo agregadas por servicio (ventana de 1 min).",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineWidth": 1,
            "showPoints": "never",
            "spanNulls": true
          },
          "unit": "reqps"
        }
      },
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 7 },
      "id": 2,
      "options": {
        "legend": { "calcs": ["mean", "lastNotNull"], "displayMode": "table", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (job) (rate(http_server_requests_seconds_count[1m]))",
          "legendFormat": "{{job}} (spring)",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (job) (rate(http_requests_total[1m]))",
          "legendFormat": "{{job}}",
          "refId": "B"
        }
      ],
      "title": "Tasa de peticiones por servicio",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Latencia promedio = sum(duration) / count(duration) en ventana de 1 min.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 5,
            "lineWidth": 1,
            "showPoints": "never",
            "spanNulls": true
          },
          "unit": "s"
        }
      },
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 7 },
      "id": 3,
      "options": {
        "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (job) (rate(http_server_requests_seconds_sum[1m])) / sum by (job) (rate(http_server_requests_seconds_count[1m]) > 0)",
          "legendFormat": "{{job}} (spring)",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (job) (rate(http_request_duration_seconds_sum[1m])) / sum by (job) (rate(http_request_duration_seconds_count[1m]) > 0)",
          "legendFormat": "{{job}}",
          "refId": "B"
        }
      ],
      "title": "Latencia promedio por servicio",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Tasa de errores HTTP 4xx y 5xx por servicio.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "fillOpacity": 10, "showPoints": "never", "spanNulls": true },
          "unit": "reqps"
        }
      },
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 16 },
      "id": 4,
      "options": {
        "legend": { "calcs": ["mean", "lastNotNull"], "displayMode": "table", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (job, status) (rate(http_server_requests_seconds_count{status=~\"[45]..\"}[1m]))",
          "legendFormat": "{{job}} {{status}} (spring)",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (job, status) (rate(http_requests_total{status=~\"[45]..\"}[1m]))",
          "legendFormat": "{{job}} {{status}}",
          "refId": "B"
        }
      ],
      "title": "Errores HTTP 4xx / 5xx",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "loki", "uid": "loki" },
      "description": "Últimos errores de cualquier microservicio (vía Loki, filtrando por nivel ERROR/WARN o status >= 500).",
      "fieldConfig": { "defaults": {}, "overrides": [] },
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 16 },
      "id": 5,
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": true,
        "showCommonLabels": false,
        "showLabels": false,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": true
      },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "{service=~\"empleados-service|departamentos|notificaciones|autenticacion-service|perfiles-service|autenticacion|perfiles\"} |~ \"(?i)error|exception|fail|level=ERROR|level=WARN\"",
          "refId": "A"
        }
      ],
      "title": "Logs recientes con errores (Loki)",
      "type": "logs"
    }
  ],
  "refresh": "10s",
  "schemaVersion": 39,
  "tags": ["microservicios", "reto7"],
  "templating": { "list": [] },
  "time": { "from": "now-15m", "to": "now" },
